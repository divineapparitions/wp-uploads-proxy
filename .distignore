# .distignore — files excluded from the WordPress.org plugin build.
#
# Consumed by the WordPress.org deploy step (e.g.
# 10up/action-wordpress-plugin-deploy). Everything listed here stays in the
# Git repo but is NOT shipped to users in the installed plugin.
#
# This plugin has no runtime Composer dependencies and loads its own classes via
# autoload.php (a self-contained PSR-4 autoloader), so vendor/ and node_modules/
# are development tooling only and never ship — both are excluded below.

# Version control / CI
/.git
/.gitattributes
/.gitignore
/.distignore
/.github

# Dev dependencies (not needed at runtime — see autoload.php)
/vendor
/node_modules

# Local dev environment
/.editorconfig
/.wp-env.json

# Tests
/tests
/phpunit.xml.dist
/phpunit-integration.xml.dist

# Tooling config
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist

# Project docs not needed inside the installed plugin
/docs
/CONTEXT.md
/CONTRIBUTING.md
/CLA.md
/CHANGELOG.md
/README.md
